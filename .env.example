# Database
ConnectionStrings__EmailWorkerDb=Host=postgres;Port=5432;Database=metria_emailworker;Username=postgres;Password=postgres

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_QUEUE_EMAIL_DIGEST=email.digest

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=smtp-user
SMTP_PASSWORD=smtp-password
SMTP_FROM=no-reply@example.com

# Optional SendGrid (if set, SendGrid is used instead of SMTP)
SENDGRID_API_KEY=
SENDGRID_FROM=

# Scheduler config (validated, consumer-only worker)
EMAIL_DIGEST_ENABLED=true
EMAIL_DIGEST_CRON="0 9 * * MON,THU"
EMAIL_DIGEST_TIMEZONE_DEFAULT=UTC

# Retry
EMAIL_RETRY_MAX_ATTEMPTS=5
EMAIL_RETRY_BASE_DELAY_SECONDS=2
EMAIL_RETRY_MAX_DELAY_SECONDS=60
